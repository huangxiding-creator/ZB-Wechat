{
  "name": "wechat-article-exporter",
  "version": "1.2.0",
  "description": "One-click export all WeChat official account articles to Markdown. 一键导出微信公众号所有历史文章。",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wechat-export": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "intelligence": "ts-node src/intelligence/index.ts once",
    "intelligence:schedule": "ts-node src/intelligence/index.ts schedule",
    "intelligence:ui": "ts-node src/intelligence/index.ts --ui",
    "clean": "rimraf dist coverage",
    "lint": "eslint src/**/*.ts --fix",
    "lint:check": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "keywords": [
    "wechat",
    "weixin",
    "article",
    "export",
    "download",
    "markdown",
    "scraper",
    "official-account",
    "公众号",
    "微信",
    "文章导出",
    "batch-download"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/huangxiding-creator/Auto-wechat-article-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/huangxiding-creator/Auto-wechat-article-exporter/issues"
  },
  "homepage": "https://github.com/huangxiding-creator/Auto-wechat-article-exporter#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "README_CN.md",
    "LICENSE"
  ],
  "dependencies": {
    "@types/node-cron": "^3.0.11",
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "ora": "^9.3.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.2.5",
    "rimraf": "^6.0.1",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/index.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "jest-junit": {
    "outputDirectory": "./coverage",
    "outputName": "junit.xml"
  }
}
